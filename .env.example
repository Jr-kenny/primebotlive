VITE_BASE_RPC_URL=https://sepolia.base.org
VITE_REOWN_PROJECT_ID=
VITE_APP_URL=http://localhost:8080

# PrimeBot charges callers on /execute by requiring a direct ETH payment to the
# treasury address before execution. If omitted, the backend wallet address
# derived from PRIMEBOT_PRIVATE_KEY is used as treasury.
TREASURY_ADDRESS=
EXECUTION_FEE_WEI=100000000000000
PAYMENT_LEDGER_PATH=.primebot-payment-ledger.json

# Optional direct TEE override. Leave blank to resolve the active OpenGradient
# LLM TEE from the on-chain registry, which is the default production path.
OPENGRADIENT_URL=
OPENGRADIENT_RPC_URL=https://ogevmdevnet.opengradient.ai
OPENGRADIENT_TEE_REGISTRY_ADDRESS=0x4e72238852f3c918f4E4e57AeC9280dDB0c80248
OPENGRADIENT_MODEL=openai/gpt-4.1-2025-04-14
OPENGRADIENT_SETTLEMENT_TYPE=individual
ZEROX_API_URL=https://api.0x.org
ZEROX_API_KEY=
LIFI_API_URL=https://li.quest/v1
LIFI_INTEGRATOR=PrimeBot
ACROSS_API_URL=https://testnet.across.to/api
ACROSS_INTEGRATOR_ID=

